# LINE Bot 配置
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# 用户 ID（可选 - 用于发送个人提醒）
USER_A_ID=user_a_line_id_here
USER_B_ID=user_b_line_id_here

# 报告发送对象（可选 - 用于每日报告）
REPORT_USER_ID=report_recipient_line_id_here

# Perplexity AI API
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# 月度 API 使用额度限制
MONTHLY_API_LIMIT=500

# Notion 集成（可选）
NOTION_TOKEN=your_notion_api_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Make.com Webhook（可选 - 用于自动化提醒）
MAKE_WEBHOOK_URL=https://your.make.com.webhook.url.here

# Replit 特定变量（自动设置）
# REPLIT_DEV_DOMAIN=projectname.replit.dev
